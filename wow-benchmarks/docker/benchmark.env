WOW_BENCHMARK_REDIS_PROJECT_NAME=wow-benchmarks-redis
WOW_BENCHMARK_REDIS_IMAGE=redis:7.4.9-alpine
WOW_BENCHMARK_REDIS_CONTAINER_NAME=wow-benchmark-redis
WOW_BENCHMARK_REDIS_HOST=localhost
WOW_BENCHMARK_REDIS_HOST_PORT=6379
WOW_BENCHMARK_REDIS_DATA_TMPFS_SIZE=1024m

WOW_BENCHMARK_MONGO_PROJECT_NAME=wow-benchmarks-mongo
WOW_BENCHMARK_MONGO_IMAGE=mongo:8.3.4
WOW_BENCHMARK_MONGO_CONTAINER_NAME=wow-benchmark-mongo
WOW_BENCHMARK_MONGO_HOST=localhost
WOW_BENCHMARK_MONGO_HOST_PORT=27017
WOW_BENCHMARK_MONGO_ROOT_USERNAME=root
WOW_BENCHMARK_MONGO_ROOT_PASSWORD=root
WOW_BENCHMARK_MONGO_DATA_TMPFS_SIZE=4096m
WOW_BENCHMARK_MONGO_CONFIGDB_TMPFS_SIZE=512m
WOW_BENCHMARK_MONGO_WIREDTIGER_CACHE_GB=2
